{
    "name": "dnsrobot/dnsrobot",
    "description": "PHP client for the DNS Robot API — DNS lookups, WHOIS, SSL checks, SPF/DKIM/DMARC validation, and more.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://dnsrobot.net",
    "keywords": ["dns", "whois", "ssl", "spf", "dkim", "dmarc", "network", "lookup", "api"],
    "authors": [
        {
            "name": "DNS Robot",
            "email": "packagist@dnsrobot.net",
            "homepage": "https://dnsrobot.net"
        }
    ],
    "support": {
        "issues": "https://github.com/dnsrobot/dnsrobot-php/issues",
        "source": "https://github.com/dnsrobot/dnsrobot-php"
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "DNSRobot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DNSRobot\\Tests\\": "tests/"
        }
    }
}
